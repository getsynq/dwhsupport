# Trino / Starburst
STARBURST_USER=
STARBURST_PASSWORD=

# ClickHouse (local instance defaults)
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=getsynq10
CLICKHOUSE_DATABASE=kernel_runs

# Trino (local instance defaults)
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_USER=trino
TRINO_PASSWORD=trino

# BigQuery
BIGQUERY_PROJECT_ID=
BIGQUERY_CREDENTIALS_FILE=
