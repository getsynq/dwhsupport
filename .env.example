# Copy this file to .env and fill in your credentials for local integration testing.
# .env is gitignored - never commit real credentials.

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
# For key pair auth, set either SNOWFLAKE_PRIVATE_KEY_FILE (path to .pem) or SNOWFLAKE_PRIVATE_KEY (PEM content)
SNOWFLAKE_PRIVATE_KEY_FILE=
SNOWFLAKE_PRIVATE_KEY=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_TABLE=

# Databricks
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=
DATABRICKS_TABLE=

# Trino / Starburst
STARBURST_USER=
STARBURST_PASSWORD=

# ClickHouse (local instance defaults)
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=getsynq10
CLICKHOUSE_DATABASE=kernel_runs
CLICKHOUSE_NO_SSL=true

# Trino (local instance defaults)
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_USER=trino
TRINO_PASSWORD=trino

# Trino test table config (for monitor/metrics execution tests)
# Set these to point to a table with segment, numeric, and time columns
TRINO_TEST_TABLE=tpch.tiny.orders
TRINO_TEST_SCHEMA=tiny
TRINO_TEST_TABLE_NAME=orders
TRINO_TEST_SEGMENT_FIELD=orderstatus
TRINO_TEST_NUMERIC_FIELD=totalprice
TRINO_TEST_TIME_FIELD=orderdate

# BigQuery
BIGQUERY_PROJECT_ID=
BIGQUERY_CREDENTIALS_FILE=
BIGQUERY_REGION=EU

# Oracle (dwhtesting staging defaults)
ORACLE_HOST=127.0.0.1
ORACLE_PORT=1521
ORACLE_USER=synq
ORACLE_PASSWORD=SynqTest1
ORACLE_SERVICE=FREEPDB1

# MSSQL (dwhtesting staging defaults)
MSSQL_HOST=127.0.0.1
MSSQL_PORT=1433
MSSQL_USER=synq
MSSQL_PASSWORD=SynqTest1!
MSSQL_DATABASE=synq_test
MSSQL_ENCRYPT=disable
MSSQL_SA_PASSWORD=SynqTest1!

# PostgreSQL (dwhtesting staging defaults)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=synq
POSTGRES_PASSWORD=SynqTest1!
POSTGRES_DATABASE=synq_test

# MySQL/MariaDB (dwhtesting staging defaults)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=synq
MYSQL_PASSWORD=SynqTest1!
MYSQL_DATABASE=synq_test
